# syntax=docker/dockerfile:1
FROM golang:1.21-alpine AS builder

WORKDIR /coordinator
COPY coordinator/go.mod coordinator/go.sum ./
RUN go mod download

COPY coordinator/ ./
COPY shared/ ../shared/

RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o /app/coordinator ./cmd

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /app
COPY --from=builder /app/coordinator .
EXPOSE 50051 8080
ENTRYPOINT ["./coordinator"]
